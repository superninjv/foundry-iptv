# foundry-iptv — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# Postgres (foundry-01 local — no TLS needed on LAN)
DATABASE_URL=postgres://iptv:CHANGEME@localhost:5432/foundry_iptv

# Redis (foundry-01 local)
REDIS_URL=redis://localhost:6379/3

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://iptv.foundry.test

# Threadfin (runs in Docker on foundry-01, fronted by Caddy)
THREADFIN_URL=http://threadfin.foundry.test
THREADFIN_M3U_PATH=/m3u/threadfin.m3u
THREADFIN_XMLTV_PATH=/xmltv/threadfin.xml

# Sidecars (bound to localhost, proxied by Next API routes)
TS2HLS_URL=http://localhost:3103
MULTIVIEW_ROTOR_URL=http://localhost:3104

# Ollama (AI search + multiview layout)
OLLAMA_URL=http://localhost:11434
