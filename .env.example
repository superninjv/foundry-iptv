# foundry-iptv — environment variables
# Copy to .env.local for bare-metal dev, or .env for docker compose.
# Never commit .env or .env.local.
#
# RAW_M3U_URL and RAW_XMLTV_URL are configured via the first-run web wizard
# and stored in the iptv_config table — you do NOT need to set them here.

# ── Postgres ──────────────────────────────────────────────────────────────────
# Docker compose service name is "postgres"; bare-metal use localhost.
POSTGRES_USER=foundry
POSTGRES_PASSWORD=<generated>
POSTGRES_DB=foundry
DATABASE_URL=postgresql://foundry:<generated>@postgres:5432/foundry

# Redis (compose service name "redis"; bare-metal use localhost:6379/3)
REDIS_URL=redis://redis:6379/0

# NextAuth
NEXTAUTH_SECRET=<generated>
NEXTAUTH_URL=http://localhost

# Threadfin (runs in Docker on foundry-01, fronted by Caddy).
# Threadfin still runs but the channel/EPG data path bypasses its curation —
# foundry-iptv reads the raw upstream M3U + XMLTV directly via Caddy
# file_server (`handle_path /raw/*`) so the full ~52K live channels are
# visible. Threadfin URL is still used as the default base for the raw paths.
THREADFIN_URL=http://threadfin.foundry.test

# Optional explicit overrides for the raw provider files. Defaults are
# `${THREADFIN_URL}/raw/prime.m3u` and `${THREADFIN_URL}/raw/prime.xml` —
# only set these if you move the files behind a different host/path.
# RAW_M3U_URL=http://threadfin.foundry.test/raw/prime.m3u
# RAW_XMLTV_URL=http://threadfin.foundry.test/raw/prime.xml

# Sidecars (compose: use service names; bare-metal: use localhost)
TS2HLS_URL=http://ts2hls:3103
TS2HLS_SHARED_SECRET=<generated>
# Inbound bearer for ts2hls -> foundry-iptv commercial-detection signals.
# Distinct from TS2HLS_SHARED_SECRET (which is outbound). Set the same value
# in services/ts2hls's environment so the signal POSTs authenticate.
TS2HLS_BEARER_TOKEN=<generated>
# Set to "true" inside ts2hls to enable ffmpeg silence/blackframe detection.
ENABLE_COMMERCIAL_DETECTION=false

# Optional comma-separated allowlist of upstream stream hosts for ts2hls.
# Leave empty to allow any non-private host (the default).
# STREAM_ALLOWED_HOSTS=line.primelivestreaming.org

# Display timezone for server-rendered dates/times. Defaults to
# America/New_York (handles EST↔EDT automatically). Set to your IANA tz.
APP_TIMEZONE=America/New_York

# Ollama (AI search + multiview layout)
OLLAMA_URL=http://localhost:11434

# Drop 3x3 and 2+4 multiview back to source passthrough instead of server-side
# transcode. Use on hosts that can't sustain 6+ concurrent ffmpeg transcodes
# (e.g. the foundry-01 Xeon 4108). Leave unset on beefier hardware.
# NEXT_PUBLIC_MULTIVIEW_LOW_CPU=true
