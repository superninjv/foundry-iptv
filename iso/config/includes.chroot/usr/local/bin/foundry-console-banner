#!/usr/bin/env bash
# Foundry IPTV console status banner
# Runs on tty1, refreshes every 30 seconds

readonly GREEN='\033[1;32m'
readonly YELLOW='\033[1;33m'
readonly RED='\033[1;31m'
readonly CYAN='\033[1;36m'
readonly BOLD='\033[1m'
readonly DIM='\033[2m'
readonly RESET='\033[0m'

print_banner() {
  clear

  # Detect IP
  local ip_addr
  ip_addr="$(hostname -I 2>/dev/null | awk '{print $1}')"
  ip_addr="${ip_addr:-<no network>}"

  # Check stack health
  local status status_color
  if curl -fsS http://localhost/api/health >/dev/null 2>&1; then
    status="RUNNING"
    status_color="$GREEN"
  elif [ -f /opt/foundry/.firstboot-done ]; then
    if docker compose -f /opt/foundry/docker-compose.yml ps --format '{{.State}}' 2>/dev/null | grep -q running; then
      status="STARTING"
      status_color="$YELLOW"
    else
      status="STOPPED"
      status_color="$RED"
    fi
  else
    status="FIRST BOOT IN PROGRESS"
    status_color="$YELLOW"
  fi

  local uptime_str
  uptime_str="$(uptime -p 2>/dev/null | sed 's/up //' || echo 'unknown')"

  printf '\n'
  printf "${BOLD}  ╔═══════════════════════════════════════════════════════╗${RESET}\n"
  printf "${BOLD}  ║${RESET}${CYAN}           Foundry IPTV Appliance                    ${RESET}${BOLD}║${RESET}\n"
  printf "${BOLD}  ╠═══════════════════════════════════════════════════════╣${RESET}\n"
  printf "${BOLD}  ║${RESET}                                                       ${BOLD}║${RESET}\n"
  printf "${BOLD}  ║${RESET}  Status:  ${status_color}%-44s${RESET}${BOLD}║${RESET}\n" "$status"
  printf "${BOLD}  ║${RESET}  Uptime:  ${DIM}%-44s${RESET}${BOLD}║${RESET}\n" "$uptime_str"
  printf "${BOLD}  ║${RESET}                                                       ${BOLD}║${RESET}\n"
  printf "${BOLD}  ║${RESET}  Open in your browser:                                ${BOLD}║${RESET}\n"
  printf "${BOLD}  ║${RESET}    ${GREEN}http://foundry.local${RESET}                               ${BOLD}║${RESET}\n"
  printf "${BOLD}  ║${RESET}    ${GREEN}http://%-40s${RESET}${BOLD}║${RESET}\n" "$ip_addr"
  printf "${BOLD}  ║${RESET}                                                       ${BOLD}║${RESET}\n"
  printf "${BOLD}  ║${RESET}  SSH access:                                          ${BOLD}║${RESET}\n"
  printf "${BOLD}  ║${RESET}    ${DIM}ssh foundry@%-36s${RESET}${BOLD}║${RESET}\n" "$ip_addr"
  printf "${BOLD}  ║${RESET}                                                       ${BOLD}║${RESET}\n"
  printf "${BOLD}  ╚═══════════════════════════════════════════════════════╝${RESET}\n"
  printf '\n'
  printf "${DIM}  Press Ctrl+C for shell. Banner refreshes every 30s.${RESET}\n"
}

# Initial display
print_banner

# Refresh loop
while true; do
  sleep 30
  print_banner
done
